# chatrxiv environment variables
#
# Copy this file to `.env` for local development if desired.
# Frontend-only variables can also be set in `web/.env.local`.

# Path to the normalized chats database.
# Default: OS-specific app data directory, e.g. ~/.local/share/chatrxiv/chats.db on Linux
CHATRXIV_DB_PATH=

# Optional: path to the raw ELT archive database.
# Default: raw.db next to the default chats.db location
CHATRXIV_RAW_DB_PATH=

# Enable or disable automatic startup ingestion and file watching for the web API.
# Default: true
CHATRXIV_WATCH=true

# Comma-separated list of allowed browser origins for the FastAPI server.
# Default: http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: Anthropic API key for chat summarization features.
ANTHROPIC_API_KEY=

# Browser-visible API base URL for the Next.js frontend.
# Default: http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional: Claude.ai organization ID for direct web ingestion.
# Alternative to env vars: configure dlt secrets at sources.claude_conversations.org_id
CLAUDE_ORG_ID=

# Optional: Claude.ai session cookie value (sessionKey) for direct web ingestion.
# Alternative to env vars: configure dlt secrets at sources.claude_conversations.session_cookie
CLAUDE_SESSION_COOKIE=

# Optional: ChatGPT session token for direct web ingestion.
# Alternative to env vars: configure dlt secrets at sources.chatgpt_conversations.session_token
CHATGPT_SESSION_TOKEN=

# Optional advanced ChatGPT cookies used by some environments.
# If unset, ChatGPTReader falls back to dlt secrets when available.
CHATGPT_CSRF_TOKEN=
CHATGPT_CF_CLEARANCE=
CHATGPT_OAI_DID=
CHATGPT_PUID=
